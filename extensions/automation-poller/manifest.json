{
  "manifest_version": 3,
  "name": "Grybuges Automation Poller",
  "description": "Polls the alert bot backend for browser automation commands.",
  "version": "0.1.0",
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://gyrbuges.duckdns.org/*"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Automation Poller",
    "default_popup": "popup.html"
  }
}
